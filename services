    <script>
        // User Data
        const users = [
            { email: 'admin@digimark.com', password: 'password123', name: 'Admin User', type: 'admin' },
            { email: 'user@test.com', password: 'user123', name: 'Test User', type: 'user' }
        ];

        // Current logged in user
        let currentUser = null;

        // Orders array
        let userOrders = [];

        // Load orders from localStorage
        function loadOrders() {
            const savedOrders = localStorage.getItem('userOrders');
            if (savedOrders) {
                userOrders = JSON.parse(savedOrders);
            }
        }

        // Save orders to localStorage
        function saveOrders() {
            localStorage.setItem('userOrders', JSON.stringify(userOrders));
        }

        // Login Modal
        const modal = document.getElementById('loginModal');
        const loginBtn = document.getElementById('loginBtn');
        const closeBtn = document.querySelector('.close');

        loginBtn.onclick = function(e) {
            e.preventDefault();
            modal.classList.add('active');
        }

        closeBtn.onclick = function() {
            modal.classList.remove('active');
        }

        window.onclick = function(event) {
            if (event.target == modal) {
                modal.classList.remove('active');
            }
        }

        // Login Form
        document.getElementById('loginForm').onsubmit = function(e) {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const messageDiv = document.getElementById('loginMessage');

            // Find user
            const user = users.find(u => u.email === email && u.password === password);

            if (user) {
                currentUser = user;
                messageDiv.innerHTML = '<div class="alert success">Login successful! Redirecting...</div>';
                
                setTimeout(() => {
                    modal.classList.remove('active');
                    updateUIForLoggedInUser();
                    document.getElementById('loginForm').reset();
                }, 1500);
            } else {
                messageDiv.innerHTML = '<div class="alert error">Invalid email or password!</div>';
            }
        }

        // Update UI after login
        function updateUIForLoggedInUser() {
            if (currentUser) {
                document.getElementById('userDisplay').innerHTML = `Welcome, ${currentUser.name} <button class="logout-btn" onclick="logout()">Logout</button>`;
                document.getElementById('userDisplay').classList.add('active');
                document.getElementById('dashboard').classList.add('active');
                document.getElementById('userName').textContent = currentUser.name;
                loginBtn.style.display = 'none';
                
                // Load user orders
                loadOrders();
                updateDashboardOrders();
            }
        }

        // Update dashboard with orders
        function updateDashboardOrders() {
            if (!currentUser) return;
            
            const userSpecificOrders = userOrders.filter(order => order.userEmail === currentUser.email);
            
            document.getElementById('activeOrders').textContent = userSpecificOrders.filter(o => o.status === 'pending').length;
            document.getElementById('completedOrders').textContent = userSpecificOrders.filter(o => o.status === 'completed').length;
            
            const totalSpent = userSpecificOrders.reduce((sum, order) => {
                const price = parseFloat(order.price) || 0;
                return sum + price;
            }, 0);
            document.getElementById('totalSpent').textContent = '$' + totalSpent;
            
            const orderHistory = document.getElementById('orderHistory');
            if (userSpecificOrders.length === 0) {
                orderHistory.innerHTML = '<p>No orders yet. Start by ordering a service!</p>';
            } else {
                orderHistory.innerHTML = userSpecificOrders.map(order => `
                    <div class="order-item">
                        <div>
                            <strong>${order.service}</strong> - ${order.package} package
                            <br>
                            <small>Ordered on: ${new Date(order.date).toLocaleDateString()}</small>
                        </div>
                        <div>
                            <span class="order-status ${order.status === 'pending' ? 'status-pending' : 'status-completed'}">${order.status}</span>
                        </div>
                    </div>
                `).join('');
            }
        }

        // Logout function
        function logout() {
            currentUser = null;
            document.getElementById('userDisplay').classList.remove('active');
            document.getElementById('dashboard').classList.remove('active');
            loginBtn.style.display = 'inline-block';
        }

        // Order Modal functions
        const orderModal = document.getElementById('orderModal');
        
        function openOrderModal(serviceName) {
            if (!currentUser) {
                alert('Please login first to place an order!');
                modal.classList.add('active');
                return;
            }
            
            document.getElementById('modalServiceTitle').textContent = `Order: ${serviceName}`;
            document.getElementById('serviceName').value = serviceName;
            orderModal.classList.add('active');
        }

        function closeOrderModal() {
            orderModal.classList.remove('active');
            document.getElementById('orderForm').reset();
        }

        // Order Form
        document.getElementById('orderForm').onsubmit = function(e) {
            e.preventDefault();
            
            if (!currentUser) {
                alert('Please login first!');
                closeOrderModal();
                modal.classList.add('active');
                return;
            }
            
            const order = {
                id: Date.now(),
                userEmail: currentUser.email,
                service: document.getElementById('serviceName').value,
                customerName: document.getElementById('customerName').value,
                customerEmail: document.getElementById('customerEmail').value,
                customerPhone: document.getElementById('customerPhone').value,
                package: document.getElementById('servicePackage').value,
                details: document.getElementById('projectDetails').value,
                budget: document.getElementById('budget').value,
                status: 'pending',
                date: new Date().toISOString(),
                price: Math.floor(Math.random() * 500) + 100 // Random price for demo
            };
            
            userOrders.push(order);
            saveOrders();
            
            document.getElementById('orderMessage').innerHTML = '<div class="alert success">Order placed successfully!</div>';
            
            setTimeout(() => {
                closeOrderModal();
                updateDashboardOrders();
                alert(`Thank you for your order! We'll contact you within 24 hours.`);
            }, 1500);
        }

        // Apply for job
        function applyForJob(jobTitle) {
            if (!currentUser) {
                alert('Please login first to apply for this position!');
                modal.classList.add('active');
                return;
            }
            
            alert(`Thank you for applying for ${jobTitle} position!\nWe will review your application and contact you soon.`);
            
            // Store application in localStorage
            let applications = JSON.parse(localStorage.getItem('jobApplications') || '[]');
            applications.push({
                user: currentUser.email,
                userName: currentUser.name,
                job: jobTitle,
                date: new Date().toISOString()
            });
            localStorage.setItem('jobApplications', JSON.stringify(applications));
        }

        // Contact Form
        document.getElementById('contactForm').onsubmit = function(e) {
            e.preventDefault();
            
            const name = document.getElementById('name').value;
            const email = document.getElementById('contactEmail').value;
            const message = document.getElementById('message').value;
            
            alert(`Thank you ${name}! We have received your message and will get back to you soon.`);
            
            // Store contact in localStorage
            let contacts = JSON.parse(localStorage.getItem('contacts') || '[]');
            contacts.push({
                name: name,
                email: email,
                message: message,
                date: new Date().toISOString()
            });
            localStorage.setItem('contacts', JSON.stringify(contacts));
            
            this.reset();
        }

        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Initialize
        window.onload = function() {
            loadOrders();
        }
    </script>
</body>
</html>
